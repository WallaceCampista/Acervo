# Copie este arquivo para `.env` e ajuste os valores.
# Usado pelo docker-compose.prod.yml.

# === Servidor de IA (OpenAI-compat: Ollama, vLLM, llama.cpp, LM Studio…) ===
# URL acessível DO container (use o IP do host ou docker host gateway,
# não localhost — localhost dentro do container é o próprio container).
ACERVO_AI_BASE_URL=http://host.docker.internal:1234
ACERVO_AI_API_KEY=lm-studio
# Gemma 2 9B é só texto (sem visão). Para anexo de imagem no chat, use um
# modelo multimodal como gemma-3-4b-it.
ACERVO_CHAT_MODEL=gemma-2-9b-it
ACERVO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5@q8_0
ACERVO_EMBEDDING_DIMENSIONS=768

# === Postgres (POSTGRES_PASSWORD obrigatório) ===
POSTGRES_DB=acervo
POSTGRES_USER=acervo
POSTGRES_PASSWORD=changeme

# === App ===
APP_PORT=8080
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
